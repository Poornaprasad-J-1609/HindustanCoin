# ══════════════════════════════════════════════════════════════
#  HindustanCoin — Environment Variables
#  The app works 100% WITHOUT any API keys.
#  Adding keys enables live data from the respective services.
# ══════════════════════════════════════════════════════════════

# ── CoinGecko (Market prices, OHLC charts, authenticity checks) ──────────────
# Free public API works without a key (rate-limited to ~10-30 req/min)
# For higher limits: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# ── CryptoCompare (Live news feed) ───────────────────────────────────────────
# Get a FREE key at: https://www.cryptocompare.com/cryptopian/api-keys
CRYPTOCOMPARE_API_KEY=

# ── Groq LLM API (LLaMA-3 8B — for AI commentary) ───────────────────────────
# Get a FREE key at: https://console.groq.com/
# Without this key, rule-based commentary is used (still works great!)
GROQ_API_KEY=

# ── Twitter/X Bearer Token (live tweets for sentiment) ───────────────────────
# Optional: https://developer.x.com/
TWITTER_BEARER_TOKEN=

# ── Server Configuration ─────────────────────────────────────────────────────
BACKEND_PORT=5000
